<Window x:Class="BlueBirdsERP.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BlueBirdsERP.Desktop"
        xmlns:controls="clr-namespace:BlueBirdsERP.Desktop.Controls"
        Title="BlueBirds"
        Width="1280" Height="800"
        MinWidth="1240" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource CanvasBrush}"
        FontFamily="{StaticResource AppFont}"
        Foreground="{StaticResource OnSurfaceBrush}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <local:ViewLocator x:Key="ViewLocator" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <controls:HeaderStrip Grid.Row="0" Grid.Column="1"
                              Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}" />

        <controls:SidebarControl Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                 Width="232"
                                 Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}" />

        <ContentControl Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                        Content="{Binding CurrentView}"
                        ContentTemplateSelector="{StaticResource ViewLocator}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentView}"
                        ContentTemplateSelector="{StaticResource ViewLocator}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Window>
