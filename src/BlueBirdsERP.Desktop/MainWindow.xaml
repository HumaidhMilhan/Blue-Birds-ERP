<Window x:Class="BlueBirdsERP.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BlueBirdsERP.Desktop"
        xmlns:controls="clr-namespace:BlueBirdsERP.Desktop.Controls"
        xmlns:converters="clr-namespace:BlueBirdsERP.Desktop.Converters"
        Title="PoultryPro ERP"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource OnSurfaceBrush}">

    <Window.Resources>
        <local:ViewLocator x:Key="ViewLocator" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header strip (hidden when not logged in) -->
            <RowDefinition Height="Auto" />
            <!-- Content area -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Sidebar (hidden when not logged in) -->
            <ColumnDefinition Width="Auto" />
            <!-- Main content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header strip — spans full width -->
        <controls:HeaderStrip Grid.Row="0" Grid.ColumnSpan="2"
                              Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}" />

        <!-- Sidebar -->
        <controls:SidebarControl Grid.Row="1" Grid.Column="0"
                                 Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <controls:SidebarControl.Width>
                <Binding Path="IsSidebarCollapsed">
                    <Binding.Converter>
                        <converters:CollapseWidthConverter ExpandedWidth="220" CollapsedWidth="64" />
                    </Binding.Converter>
                </Binding>
            </controls:SidebarControl.Width>
        </controls:SidebarControl>

        <!-- Login view (shown when not logged in, replaces main content) -->
        <ContentControl Grid.Row="1" Grid.ColumnSpan="2"
                        Content="{Binding CurrentView}"
                        ContentTemplateSelector="{StaticResource ViewLocator}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <!-- Main content area (shown when logged in) -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentView}"
                        ContentTemplateSelector="{StaticResource ViewLocator}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Window>
