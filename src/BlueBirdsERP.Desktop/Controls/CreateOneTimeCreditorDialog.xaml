<Window x:Class="BlueBirdsERP.Desktop.Controls.CreateOneTimeCreditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Create Walk-in Creditor" Width="480">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="New Walk-in Creditor" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,24" />

            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <TextBlock Text="FULL NAME" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="NameBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="PHONE" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="PhoneBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="WHATSAPP" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="WhatsAppBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="ADDRESS" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="AddressBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />

                <TextBlock Text="NIC / BUSINESS REG. NO" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="NicBox" Style="{StaticResource InputTextBoxStyle}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Register Creditor"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Create_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
