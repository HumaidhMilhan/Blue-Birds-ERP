<Window x:Class="BlueBirdsERP.Desktop.Controls.ProductPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Product" Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select a product"
                   Style="{StaticResource SectionHeaderStyle}" />

        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource InputTextBoxStyle}"
                 Margin="0,0,0,12" />

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredProducts}"
                  SelectedItem="{Binding SelectedProduct}"
                  Style="{StaticResource DataGridStyle}"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                <DataGridTextColumn Header="UoM" Binding="{Binding UnitOfMeasure}" Width="80" />
                <DataGridTextColumn Header="Stock" Binding="{Binding RemainingQuantity, StringFormat=N2}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button Content="Select"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Select_Click" />
        </StackPanel>
    </Grid>
</Window>
