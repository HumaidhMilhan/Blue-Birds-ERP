<Window x:Class="BlueBirdsERP.Desktop.Controls.ProductPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Select Product" Width="600">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Select Product" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,20" />

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Padding="40,12,12,12"
                         Tag="Search products..." />
                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                      Fill="{StaticResource OnSurfaceVariantBrush}" 
                      Width="18" Height="18" 
                      HorizontalAlignment="Left" 
                      Margin="12,0,0,0" 
                      VerticalAlignment="Center" />
            </Grid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding FilteredProducts}"
                      SelectedItem="{Binding SelectedProduct}"
                      Style="{StaticResource DataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      MaxHeight="300"
                      Margin="0,0,0,24">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Unit" Binding="{Binding UnitOfMeasure}" Width="80" />
                    <DataGridTextColumn Header="Price" Binding="{Binding SellingPrice, StringFormat=N2}" Width="120" FontWeight="Bold" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Select Product"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Select_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
