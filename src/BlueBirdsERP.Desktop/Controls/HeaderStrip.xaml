<UserControl x:Class="BlueBirdsERP.Desktop.Controls.HeaderStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource SurfaceContainerLowestBrush}"
            BorderBrush="{StaticResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,12">
        <DockPanel>
            <!-- Logout (right) -->
            <Button DockPanel.Dock="Right"
                    Content="Logout"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="16,6"
                    FontSize="13"
                    VerticalAlignment="Center" />

            <!-- Role badge (right) -->
            <Border DockPanel.Dock="Right"
                    Background="{StaticResource SurfaceContainerBrush}"
                    CornerRadius="9999"
                    Padding="14,5"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OnSurfaceVariantBrush}">
                    <Run Text="{Binding CurrentRole}" />
                </TextBlock>
            </Border>

            <!-- DateTime (right) -->
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding CurrentDateTime}"
                       FontSize="13"
                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />

            <!-- Username (right) -->
            <TextBlock DockPanel.Dock="Right"
                       FontSize="13"
                       Foreground="{StaticResource OnSurfaceBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0">
                <Run Text="{Binding CurrentUsername}" />
            </TextBlock>

            <!-- Page title (left, fills remaining) -->
            <TextBlock Text="{Binding CurrentPageTitle}"
                       Style="{StaticResource PageHeaderStyle}"
                       VerticalAlignment="Center" />
        </DockPanel>
    </Border>
</UserControl>
