<UserControl x:Class="BlueBirdsERP.Desktop.Controls.HeaderStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Height="88"
            Margin="24,16,24,0"
            Padding="24,0"
            Background="{StaticResource SurfaceContainerLowestBrush}"
            BorderBrush="{StaticResource OutlineVariantBrush}"
            BorderThickness="1"
            CornerRadius="26">
        <Border.Effect>
            <DropShadowEffect Color="#3B2F45" BlurRadius="22" ShadowDepth="5" Opacity="0.07" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentPageTitle, FallbackValue=Workspace}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}" />
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <Border Background="{StaticResource PrimaryContainerBrush}"
                            CornerRadius="16"
                            Padding="10,4"
                            Margin="0,0,10,0">
                        <TextBlock Text="Cashier tablet workspace"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OnPrimaryContainerBrush}" />
                    </Border>
                    <TextBlock Text="{Binding CurrentDateTime}"
                               FontSize="12"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="340"
                        Height="48"
                        Background="{StaticResource FieldBrush}"
                        CornerRadius="24"
                        Padding="18,0"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                              Fill="{StaticResource OnSurfaceVariantBrush}"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"
                              Margin="0,0,12,0" />
                        <TextBlock Text="Search invoice, customer, product"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Width="48"
                        Height="48"
                        MinHeight="48"
                        Padding="0"
                        ToolTip="Notifications"
                        Margin="0,0,12,0">
                    <Path Data="M12,22A2.5,2.5 0 0,0 14.45,20H9.55A2.5,2.5 0 0,0 12,22M18,16V11C18,7.93 16.36,5.36 13.5,4.68V4A1.5,1.5 0 0,0 12,2.5A1.5,1.5 0 0,0 10.5,4V4.68C7.63,5.36 6,7.92 6,11V16L4,18V19H20V18L18,16Z"
                          Fill="{StaticResource OnSecondaryContainerBrush}"
                          Width="19"
                          Height="19"
                          Stretch="Uniform" />
                </Button>

                <Button Command="{Binding NavigateToSettingsCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        Padding="8"
                        ToolTip="Profile and settings"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48"
                                Height="48"
                                Background="{StaticResource LavenderPastelBrush}"
                                CornerRadius="24"
                                Margin="0,0,12,0">
                            <TextBlock Text="B"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Width="108">
                            <TextBlock Text="{Binding CurrentUsername}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentRole}"
                                       FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LogoutCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        Width="48"
                        Height="48"
                        MinHeight="48"
                        Padding="0"
                        ToolTip="Sign out">
                    <Path Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z"
                          Fill="{StaticResource OnSurfaceVariantBrush}"
                          Width="19"
                          Height="19"
                          Stretch="Uniform" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
