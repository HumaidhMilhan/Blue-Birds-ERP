<Window x:Class="BlueBirdsERP.Desktop.Controls.AddProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Add Product" Width="480">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Add New Product" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4" />
                <TextBlock Text="Define the basic properties of your poultry product" 
                           FontSize="13" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <TextBlock Text="PRODUCT NAME" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="NameBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20" />

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="PRICING TYPE" Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="PricingTypeBox" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="WeightBased" IsSelected="True" />
                            <ComboBoxItem Content="UnitBased" />
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UNIT (kg, piece, tray)" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="UoMBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="SELLING PRICE" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="PriceBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="REORDER LEVEL" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="ReorderBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Create Product"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Create_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
