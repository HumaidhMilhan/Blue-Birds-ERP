<Window x:Class="BlueBirdsERP.Desktop.Controls.RecordPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Record Payment" Width="450">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Record Account Payment" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,24" />

            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <Border Background="{StaticResource ErrorContainerBrush}"
                        CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="TOTAL OUTSTANDING" Style="{StaticResource LabelStyle}" Foreground="{StaticResource ErrorBrush}" Opacity="0.8" />
                        <TextBlock x:Name="OutstandingText" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource ErrorBrush}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="PAYMENT AMOUNT" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="AmountBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20" />

                <TextBlock Text="PAYMENT METHOD" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="PaymentMethodBox" Style="{StaticResource InputComboBoxStyle}" Margin="0,0,0,20">
                    <ComboBoxItem Content="Cash" IsSelected="True" />
                    <ComboBoxItem Content="Card" />
                </ComboBox>

                <TextBlock Text="REFERENCE (OPTIONAL)" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="ReferenceBox" Style="{StaticResource InputTextBoxStyle}" Tag="e.g. Check number or bank ref" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Record Payment"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Record_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
