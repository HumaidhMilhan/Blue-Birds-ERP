<Window x:Class="BlueBirdsERP.Desktop.Controls.RecordPurchaseDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Record Batch Purchase" Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Record Batch Purchase" Style="{StaticResource SectionHeaderStyle}" />

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Product" Style="{StaticResource LabelStyle}" />
            <ComboBox x:Name="ProductBox" DisplayMemberPath="ProductName" Margin="0,0,0,12" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Purchase Date" Style="{StaticResource LabelStyle}" />
                    <DatePicker x:Name="PurchaseDatePicker" SelectedDate="{x:Static sys:DateTime.Today}" Margin="0,0,0,12" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Expiry Date (optional)" Style="{StaticResource LabelStyle}" />
                    <DatePicker x:Name="ExpiryDatePicker" Margin="0,0,0,12" />
                </StackPanel>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Quantity" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="QuantityBox" Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Cost Price (per unit)" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="CostPriceBox" Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button Content="Record"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Record_Click" />
        </StackPanel>
    </Grid>
</Window>
