<Window x:Class="BlueBirdsERP.Desktop.Controls.RecordPurchaseDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Style="{StaticResource DialogWindowStyle}"
        Title="Record Batch Purchase" Width="500">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Record Inventory Purchase" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,24" />

            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <TextBlock Text="PRODUCT" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="ProductBox" Style="{StaticResource InputComboBoxStyle}" DisplayMemberPath="ProductName" Margin="0,0,0,20" />

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="PURCHASE DATE" Style="{StaticResource LabelStyle}" />
                        <DatePicker x:Name="PurchaseDatePicker" SelectedDate="{x:Static sys:DateTime.Today}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="EXPIRY DATE (OPT)" Style="{StaticResource LabelStyle}" />
                        <DatePicker x:Name="ExpiryDatePicker" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="QUANTITY" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="QuantityBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="COST PRICE (RS.)" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="CostPriceBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Record Batch"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Record_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
