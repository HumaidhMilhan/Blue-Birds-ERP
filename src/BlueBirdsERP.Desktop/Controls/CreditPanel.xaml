<UserControl x:Class="BlueBirdsERP.Desktop.Controls.CreditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}"
            Visibility="{Binding CreditSummary, Converter={StaticResource BoolToVis}}"
            Padding="16"
            Background="{StaticResource SurfaceElevatedBrush}"
            Margin="0,8,0,0">
        <StackPanel>
            <DockPanel Margin="0,0,0,14">
                <TextBlock Text="Customer Credit Profile"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" />
                <Border DockPanel.Dock="Right" Background="{StaticResource PrimaryContainerBrush}" CornerRadius="8" Padding="8,3">
                    <TextBlock Text="CREDIT ACTIVE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </Border>
            </DockPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="OUTSTANDING" Style="{StaticResource LabelStyle}" />
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}">
                        <Run Text="{Binding CreditSummary.OutstandingBalance, Converter={StaticResource CurrencyFormat}}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="CREDIT LIMIT" Style="{StaticResource LabelStyle}" />
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}">
                        <Run Text="{Binding CreditSummary.CreditLimit, Converter={StaticResource CurrencyFormat}}" />
                    </TextBlock>
                </StackPanel>

                <!-- Visualization -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,2,0,14">
                    <ProgressBar Height="6" Background="{StaticResource SurfaceContainerBrush}" Foreground="{StaticResource ErrorBrush}" BorderThickness="0"
                                 Value="45" Minimum="0" Maximum="100" />
                    <!-- Visual value placeholder for progress -->
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="AVAILABLE" Style="{StaticResource LabelStyle}" />
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}">
                        <Run Text="{Binding CreditSummary.AvailableCredit, Converter={StaticResource CurrencyFormat}}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="OVERDUE" Style="{StaticResource LabelStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}">
                            <Run Text="{Binding CreditSummary.OverdueInvoiceCount}" />
                        </TextBlock>
                        <TextBlock Text=" Invoices" FontSize="14" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Bottom" Margin="4,0,0,1" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
