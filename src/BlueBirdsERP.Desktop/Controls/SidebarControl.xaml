<UserControl x:Class="BlueBirdsERP.Desktop.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BlueBirdsERP.Desktop.ViewModels">

    <Border Background="{StaticResource SurfaceContainerLowBrush}"
            BorderBrush="{StaticResource OutlineVariantBrush}"
            BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- Branding / Collapse toggle -->
            <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                <Grid>
                    <Ellipse Width="40" Height="40"
                             Fill="{StaticResource PrimaryBrush}"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,12">
                        <Ellipse.OpacityMask>
                            <SolidColorBrush Color="White" />
                        </Ellipse.OpacityMask>
                    </Ellipse>
                    <!-- App name when expanded -->
                    <TextBlock Text="PoultryPro"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="48,0,0,12"
                               Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                </Grid>
                <TextBlock Text="MENU"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
            </StackPanel>

            <!-- Collapse toggle button at bottom -->
            <Button DockPanel.Dock="Bottom"
                    Margin="12,0,12,12"
                    Padding="8"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding ToggleSidebarCommand}"
                    Style="{StaticResource GhostButtonStyle}"
                    FontSize="12"
                    Content="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, FallbackValue=''}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <TextBlock Text="&#x25C0; Collapse" />
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Navigation items -->
            <ListBox ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedNavigationItem}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NavigationItem}">
                        <StackPanel Orientation="Horizontal" Margin="4,0">
                            <Path Data="{Binding IconPathData}"
                                  Fill="currentColor"
                                  Width="20" Height="20"
                                  Stretch="Uniform"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Label}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="border"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="16,12"
                                            Margin="8,2"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceContainerBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceContainerHighBrush}" />
                                            <Setter TargetName="border" Property="BorderThickness" Value="2,0,0,0" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
