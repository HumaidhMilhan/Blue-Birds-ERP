<UserControl x:Class="BlueBirdsERP.Desktop.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BlueBirdsERP.Desktop.ViewModels">

    <Border Background="{StaticResource SidebarSurfaceBrush}"
            Padding="12,18">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                <Border Width="64"
                        Height="64"
                        Background="{StaticResource HeroGradientBrush}"
                        CornerRadius="26">
                    <Grid>
                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"
                              Fill="{StaticResource PrimaryBrush}"
                              Width="25"
                              Height="30"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <TextBlock Text="BlueBirds"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0">
                <Button Style="{StaticResource GhostButtonStyle}"
                        Width="72"
                        Height="64"
                        MinHeight="64"
                        Padding="0"
                        ToolTip="Help">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="44"
                                Height="34"
                                CornerRadius="17"
                                Background="{StaticResource ButterPastelBrush}">
                            <Path Data="M11,18H13V16H11V18M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,6A3,3 0 0,0 9,9H11A1,1 0 0,1 12,8A1,1 0 0,1 13,9C13,11 10,10.75 10,14H12C12,11.75 15,11.5 15,9A3,3 0 0,0 12,6Z"
                                  Fill="{StaticResource WarningBrush}"
                                  Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Help"
                                   FontSize="11"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ListBox ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedNavigationItem}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,4"
                     HorizontalContentAlignment="Center"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NavigationItem}">
                        <StackPanel Width="78" ToolTip="{Binding Label}">
                            <Border x:Name="IconPill"
                                    Width="60"
                                    Height="38"
                                    CornerRadius="19"
                                    Background="Transparent"
                                    HorizontalAlignment="Center">
                                <Path x:Name="Icon"
                                      Data="{Binding IconPathData}"
                                      Fill="{StaticResource OnSurfaceVariantBrush}"
                                      Width="20"
                                      Height="20"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="LabelText"
                                       Text="{Binding Label}"
                                       FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="32"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="IconPill" Property="Background" Value="{StaticResource PrimaryContainerBrush}" />
                                <Setter TargetName="Icon" Property="Fill" Value="{StaticResource OnPrimaryContainerBrush}" />
                                <Setter TargetName="LabelText" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,4" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemSurface"
                                            Background="Transparent"
                                            CornerRadius="26"
                                            Padding="0,8"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource SurfaceContainerLowestBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
