<Window x:Class="BlueBirdsERP.Desktop.Controls.PriceInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Enter Price" Width="400">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,32">
                <TextBlock x:Name="PromptText"
                           FontSize="16"
                           FontWeight="Medium"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           Margin="0,0,0,20"
                           TextWrapping="Wrap" />
                
                <TextBlock Text="ENTER PRICE" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="PriceBox"
                         Style="{StaticResource InputTextBoxStyle}"
                         FontSize="24"
                         FontWeight="Bold"
                         Height="64"
                         Padding="16,12" />
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Confirm Price"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
