<Window x:Class="BlueBirdsERP.Desktop.Controls.PriceInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Price" Width="350" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="PromptText"
                       FontSize="14"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap" />
            <TextBox x:Name="PriceBox"
                     Style="{StaticResource InputTextBoxStyle}"
                     FontSize="16" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
