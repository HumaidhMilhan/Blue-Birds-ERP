<Window x:Class="BlueBirdsERP.Desktop.Controls.EditTermsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Edit Credit Terms" Width="450">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Edit Credit Terms" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,24" />

            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <TextBlock Text="MAXIMUM CREDIT LIMIT (RS.)" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="CreditLimitBox" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="CREDIT PERIOD (DAYS)" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="CreditPeriodBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NOTIFY LEAD (DAYS)" Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="NotificationLeadBox" Style="{StaticResource InputTextBoxStyle}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Save Terms"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
