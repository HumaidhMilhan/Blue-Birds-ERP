<Window x:Class="BlueBirdsERP.Desktop.Controls.BatchPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DialogWindowStyle}"
        Title="Select Batch" Width="600">

    <Border Style="{StaticResource CardStyle}" Padding="24" CornerRadius="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Select Inventory Batch" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,20" />

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Batches}"
                      SelectedItem="{Binding SelectedBatch}"
                      Style="{StaticResource DataGridStyle}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      MaxHeight="300"
                      Margin="0,0,0,24">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Batch Ref" Binding="{Binding BatchReference}" Width="*" />
                    <DataGridTextColumn Header="Purchased" Binding="{Binding PurchaseDate, StringFormat=d}" Width="110" />
                    <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryDate, StringFormat=d}" Width="110" />
                    <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQuantity, StringFormat=N1}" Width="110" FontWeight="Bold" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="22" Padding="20,16" Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ENTER QUANTITY" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="140"
                             Style="{StaticResource InputTextBoxStyle}" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,0,16,0"
                        Click="Cancel_Click" />
                <Button Content="Add to Cart"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="24,12"
                        Click="Add_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
