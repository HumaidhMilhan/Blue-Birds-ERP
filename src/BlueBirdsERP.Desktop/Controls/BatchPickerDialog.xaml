<Window x:Class="BlueBirdsERP.Desktop.Controls.BatchPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Batch" Width="550" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select a batch and enter quantity"
                   Style="{StaticResource SectionHeaderStyle}" />

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Batches}"
                  SelectedItem="{Binding SelectedBatch}"
                  Style="{StaticResource DataGridStyle}"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Batch Ref" Binding="{Binding BatchReference}" Width="120" />
                <DataGridTextColumn Header="Purchased" Binding="{Binding PurchaseDate, StringFormat=d}" Width="100" />
                <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryDate, StringFormat=d}" Width="100" />
                <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQuantity, StringFormat=N2}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                     Width="100"
                     Style="{StaticResource InputTextBoxStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,12,0"
                    Click="Cancel_Click" />
            <Button Content="Add"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Add_Click" />
        </StackPanel>
    </Grid>
</Window>
