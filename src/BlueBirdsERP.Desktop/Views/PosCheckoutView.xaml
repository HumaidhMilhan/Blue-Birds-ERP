<UserControl x:Class="BlueBirdsERP.Desktop.Views.PosCheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BlueBirdsERP.Desktop.Controls">

    <UserControl.Resources>
        <Style x:Key="SegmentedRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerLowBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource OutlineVariantBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{StaticResource SurfaceContainerHighBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{StaticResource PrimaryContainerBrush}" />
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OnPrimaryContainerBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F2" Command="{Binding AddItemCommand}" />
        <KeyBinding Key="F4" Command="{Binding SearchCustomerCommand}" />
        <KeyBinding Key="F10" Command="{Binding CompleteSaleCommand}" />
        <KeyBinding Key="Escape" Command="{Binding NewSaleCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="SALE TYPE" Style="{StaticResource LabelStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Retail"
                                         IsChecked="True"
                                         Checked="SaleRetail_Checked"
                                         GroupName="SaleType"
                                         Style="{StaticResource SegmentedRadioButtonStyle}"
                                         MinWidth="92"
                                         Margin="0,0,8,0" />
                            <RadioButton Content="Wholesale"
                                         Checked="SaleWholesale_Checked"
                                         GroupName="SaleType"
                                         Style="{StaticResource SegmentedRadioButtonStyle}"
                                         MinWidth="112" />
                            <ComboBox ItemsSource="{Binding SaleChannels}" SelectedItem="{Binding SelectedSaleChannel}" Visibility="Collapsed" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock Text="CUSTOMER" Style="{StaticResource LabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Padding="38,8,12,8" />
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                      Fill="{StaticResource OnSurfaceVariantBrush}"
                                      Width="16"
                                      Height="16"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="13,0,0,0" />
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="Search"
                                        Command="{Binding SearchCustomerCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        ToolTip="Search customer" />
                                <Button Content="Clear"
                                        Command="{Binding ClearCustomerCommand}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Margin="4,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Command="{Binding AddItemCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="38"
                            MinWidth="120"
                            VerticalAlignment="Bottom"
                            ToolTip="Add item">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                  Fill="{StaticResource OnPrimaryBrush}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0" />
                            <TextBlock Text="Add Item" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceContainerLowestBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="0"
                        ClipToBounds="True">
                    <DataGrid ItemsSource="{Binding LineItems}"
                              SelectedItem="{Binding SelectedLineItem}"
                              Style="{StaticResource DataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Batch" Binding="{Binding BatchReference}" Width="118" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding DisplayQuantity}" Width="86" />
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, Converter={StaticResource CurrencyFormat}}" Width="104" />
                            <DataGridTextColumn Header="Discount" Binding="{Binding DiscountAmount, Converter={StaticResource CurrencyFormat}}" Width="96" />
                            <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, Converter={StaticResource CurrencyFormat}}" Width="112" FontWeight="Bold" />
                            <DataGridTemplateColumn Width="52">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Width="30"
                                                Height="30"
                                                MinHeight="30"
                                                Padding="0"
                                                ToolTip="Remove item">
                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                  Fill="{StaticResource ErrorBrush}"
                                                  Width="15"
                                                  Height="15" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource SurfaceContainerLowBrush}"
                            BorderBrush="{StaticResource OutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                                  Fill="{StaticResource PrimaryBrush}"
                                  Width="15"
                                  Height="15"
                                  Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurfaceBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <controls:CreditPanel Grid.Column="1" DataContext="{Binding}" HorizontalAlignment="Right" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="Sale Summary"
                               FontSize="19"
                               FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceBrush}" />
                    <TextBlock Text="{Binding LastInvoiceNumber, FallbackValue=New invoice}"
                               FontSize="12"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TOTAL DUE"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OnPrimaryBrush}"
                                   Opacity="0.78" />
                        <TextBlock Text="{Binding GrandTotal, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OnPrimaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <TextBlock Text="PAYMENT" Style="{StaticResource LabelStyle}" />
                    <UniformGrid Columns="2" Rows="2">
                        <RadioButton Content="Cash" IsChecked="True" Checked="PaymentCash_Checked" GroupName="PaymentMethod" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,6,6" />
                        <RadioButton Content="Card" Checked="PaymentCard_Checked" GroupName="PaymentMethod" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="6,0,0,6" />
                        <RadioButton Content="Credit" Checked="PaymentCredit_Checked" GroupName="PaymentMethod" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,6,6,0" />
                        <RadioButton Content="Mixed" Checked="PaymentMixed_Checked" GroupName="PaymentMethod" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="6,6,0,0" />
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Subtotal" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding Subtotal, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Discounts" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding DiscountTotal, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}" />
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Paid" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding PaidAmount, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                    </Grid>
                    <Separator Style="{StaticResource SeparatorStyle}" Margin="0,2,0,12" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Balance" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding BalanceAmount, Converter={StaticResource CurrencyFormat}}" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                    </Grid>

                    <StackPanel Visibility="{Binding IsCreditPayment, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="CASH" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding CashAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CARD" Style="{StaticResource LabelStyle}" />
                                <TextBox Text="{Binding CardAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="DUE DATE" Style="{StaticResource LabelStyle}" />
                        <DatePicker SelectedDate="{Binding DueDate}" Height="38" Margin="0,0,0,12" />
                    </StackPanel>

                    <Border Visibility="{Binding HasReceipt, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource SuccessContainerBrush}"
                            BorderBrush="{StaticResource OutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Sale completed" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                            <TextBlock Text="{Binding LastInvoiceNumber}" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,18,0,0">
                    <Button Content="Complete Sale"
                            Command="{Binding CompleteSaleCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="44"
                            FontSize="15"
                            ToolTip="Complete sale" />
                    <Button Content="Discard and Start New"
                            Command="{Binding NewSaleCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0,8,0,0"
                            Foreground="{StaticResource ErrorBrush}"
                            ToolTip="Start a new sale" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
