<UserControl x:Class="BlueBirdsERP.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with action buttons -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="+ Product"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddProductCommand}"
                            Padding="14,8" FontSize="13" />
                    <Button Content="+ Category"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding AddCategoryCommand}"
                            Padding="14,8" FontSize="13" Margin="8,0,0,0" />
                    <Button Content="+ Purchase"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RecordPurchaseCommand}"
                            Padding="14,8" FontSize="13" Margin="8,0,0,0" />
                    <Button Content="+ Wastage"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding RecordWastageCommand}"
                            Padding="14,8" FontSize="13" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Text="Inventory Management" Style="{StaticResource PageHeaderStyle}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Alerts banner -->
        <Border Grid.Row="1"
                Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource WarningContainerBrush}"
                CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="13" Margin="0,2" Foreground="{StaticResource OnSurfaceBrush}">
                            <Run Text="&#x26A0; " Foreground="{StaticResource WarningBrush}" />
                            <Run Text="{Binding Message, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: Products table -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <!-- Search bar -->
                    <Border DockPanel.Dock="Top" Padding="16,12"
                            BorderBrush="{StaticResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="PRODUCTS" Style="{StaticResource LabelStyle}"
                                       VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,12,0" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     FontSize="13" />
                        </DockPanel>
                    </Border>

                    <!-- Product DataGrid -->
                    <DataGrid ItemsSource="{Binding FilteredProducts}"
                              SelectedItem="{Binding SelectedProduct}"
                              Style="{StaticResource DataGridStyle}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}" />
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="UoM" Binding="{Binding UnitOfMeasure}" Width="70" />
                            <DataGridTextColumn Header="Stock" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="90" />
                            <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevel, StringFormat='{}{0:N1}'}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right: Batch history panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="BATCH HISTORY" Style="{StaticResource LabelStyle}"
                               Margin="16,16,16,12" />

                    <!-- No selection placeholder -->
                    <Border Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                            Padding="20">
                        <TextBlock Text="Select a product to view batch history"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center" FontStyle="Italic" />
                    </Border>

                    <!-- Batch history -->
                    <StackPanel Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SelectedProduct.ProductName}"
                                   FontWeight="SemiBold" FontSize="15"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   Margin="16,0,16,12" />
                        <DataGrid ItemsSource="{Binding BatchHistory}"
                                  Style="{StaticResource DataGridStyle}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}" />
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Purchased" Binding="{Binding PurchasedQuantity, StringFormat='{}{0:N1}'}" Width="80" />
                                <DataGridTextColumn Header="Sold" Binding="{Binding SoldQuantity, StringFormat='{}{0:N1}'}" Width="65" />
                                <DataGridTextColumn Header="Wasted" Binding="{Binding WastedQuantity, StringFormat='{}{0:N1}'}" Width="70" />
                                <DataGridTextColumn Header="Remain" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="70" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,16,0,0" Padding="12,8"
                Background="{StaticResource SurfaceContainerBrush}" CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource OnSurfaceVariantBrush}" />
        </Border>
    </Grid>
</UserControl>
