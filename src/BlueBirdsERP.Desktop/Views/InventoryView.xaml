<UserControl x:Class="BlueBirdsERP.Desktop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with action buttons -->
        <Border Grid.Row="0" Margin="0,0,0,24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding AddProductCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Width="18" Height="18" Margin="0,0,8,0" />
                            <TextBlock Text="Add Product" VerticalAlignment="Center" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AddCategoryCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="Category" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RecordPurchaseCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19,19H5V8H19M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3Z" Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="Record Purchase" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RecordWastageCommand}" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="White" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="Wastage" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Inventory Management" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Manage your products, categories, and stock movements" 
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Alerts banner -->
        <Border Grid.Row="1"
                Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource WarningContainerBrush}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" 
                                  Fill="{StaticResource WarningBrush}" Width="18" Height="18" Margin="0,0,16,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Message}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- Left: Products table -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <!-- Search bar -->
                    <Border DockPanel.Dock="Top" Padding="24,20"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Padding="40,12,12,12" />
                            <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}" 
                                  Width="18" Height="18" 
                                  HorizontalAlignment="Left" 
                                  Margin="12,0,0,0" 
                                  VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Product DataGrid -->
                    <DataGrid ItemsSource="{Binding FilteredProducts}"
                              SelectedItem="{Binding SelectedProduct}"
                              Style="{StaticResource DataGridStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitOfMeasure}" Width="80" />
                            <DataGridTextColumn Header="In Stock" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="100" FontWeight="Bold" />
                            <DataGridTextColumn Header="Reorder Level" Binding="{Binding ReorderLevel, StringFormat='{}{0:N1}'}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right: Batch history panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0" Background="{StaticResource SurfaceElevatedBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="24,20" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="BATCH HISTORY" Style="{StaticResource LabelStyle}" Margin="0" />
                    </Border>

                    <!-- No selection placeholder -->
                    <Border Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                            Padding="48">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M20,6C20.58,6 21.05,6.2 21.42,6.59C21.8,7 22,7.45 22,8V19C22,19.55 21.8,20.03 21.41,20.41C21.03,20.8 20.55,21 20,21H4C3.45,21 2.97,20.8 2.59,20.41C2.2,20.03 2,19.55 2,19V8C2,7.45 2.2,7 2.58,6.59C2.95,6.2 3.42,6 4,6H8V4C8,3.45 8.2,2.97 8.59,2.59C8.97,2.2 9.45,2 10,2H14C14.55,2 15.03,2.2 15.41,2.59C15.8,2.97 16,3.45 16,4V6H20M10,4V6H14V4H10M4,8V19H20V8H4M12,12A2,2 0 0,1 14,14A2,2 0 0,1 12,16A2,2 0 0,1 10,14A2,2 0 0,1 12,12Z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,24" Opacity="0.1" />
                            <TextBlock Text="Select a product to view its" HorizontalAlignment="Center" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                            <TextBlock Text="individual batch movements" HorizontalAlignment="Center" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Batch history -->
                    <Grid Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Padding="24,16" Background="{StaticResource SurfaceContainerLowBrush}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedProduct.ProductName}"
                                               FontWeight="Bold" FontSize="16"
                                               Foreground="{StaticResource OnSurfaceBrush}" />
                                    <TextBlock Text="{Binding SelectedProduct.UnitOfMeasure, StringFormat='Measured in {0}'}" 
                                               FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                </StackPanel>
                            </Border>
                            
                            <DataGrid ItemsSource="{Binding BatchHistory}"
                                      Style="{StaticResource DataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource DataGridRowStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Stock In" Binding="{Binding PurchasedQuantity, StringFormat='{}{0:N1}'}" Width="*" />
                                    <DataGridTextColumn Header="Sold" Binding="{Binding SoldQuantity, StringFormat='{}{0:N1}'}" Width="*" />
                                    <DataGridTextColumn Header="Remain" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="*" FontWeight="SemiBold" />
                                    <DataGridTemplateColumn Header="Status" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter=Container}"
                                                        Padding="10,4" CornerRadius="16" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" 
                                                               FontSize="11" FontWeight="Bold" 
                                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter=Text}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,24,0,0" Padding="16,10"
                Background="{StaticResource SurfaceContainerBrush}" CornerRadius="12">
            <StackPanel Orientation="Horizontal">
                <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" 
                      Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Margin="0,0,12,0" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium"
                           Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
