<UserControl x:Class="BlueBirdsERP.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource LoginPanelGradientBrush}">
        <Grid Width="1060"
              MaxWidth="1180"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,26,0"
                    Padding="44"
                    Background="#DFFFFFFF"
                    CornerRadius="42">
                <Border.Effect>
                    <DropShadowEffect Color="#3B2F45" BlurRadius="30" ShadowDepth="8" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="68"
                                Height="68"
                                Background="{StaticResource HeroGradientBrush}"
                                CornerRadius="26"
                                Margin="0,0,16,0">
                            <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"
                                  Fill="{StaticResource PrimaryBrush}"
                                  Width="28"
                                  Height="34"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BlueBirds"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceBrush}" />
                            <TextBlock Text="Cashier workspace"
                                       FontSize="15"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                Margin="0,28,0,28">
                        <TextBlock Text="Fast billing, calm screens, fewer mistakes."
                                   FontSize="42"
                                   FontWeight="Bold"
                                   LineHeight="50"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="430" />
                        <TextBlock Text="A soft tablet-style ERP experience built for busy poultry counters."
                                   FontSize="16"
                                   LineHeight="24"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="420"
                                   Margin="0,18,0,0" />
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,10,0,0">
                        <Border Background="{StaticResource PrimaryContainerBrush}" CornerRadius="26" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="POS" FontWeight="Bold" Foreground="{StaticResource OnPrimaryContainerBrush}" />
                                <TextBlock Text="Ready" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource SagePastelBrush}" CornerRadius="26" Padding="16" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="Stock" FontWeight="Bold" Foreground="{StaticResource OnSecondaryContainerBrush}" />
                                <TextBlock Text="Tracked" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ButterPastelBrush}" CornerRadius="26" Padding="16" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Credit" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="Visible" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    BorderBrush="{StaticResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="42"
                    Padding="34">
                <Border.Effect>
                    <DropShadowEffect Color="#3B2F45" BlurRadius="34" ShadowDepth="10" Opacity="0.12" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Welcome back"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceBrush}" />
                    <TextBlock Text="Sign in to continue with BlueBirds"
                               Style="{StaticResource PageSubtitleStyle}"
                               Margin="0,6,0,30" />

                    <TextBlock Text="USERNAME" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,0,0,18" />

                    <TextBlock Text="PASSWORD" Style="{StaticResource LabelStyle}" />
                    <Grid Margin="0,0,0,20">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource PasswordBoxStyle}"
                                     Padding="16,12,48,12"
                                     PasswordChanged="PasswordBox_PasswordChanged" />
                        <TextBox x:Name="VisiblePasswordBox"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Padding="16,12,48,12"
                                 Visibility="Collapsed"
                                 TextChanged="VisiblePasswordBox_TextChanged" />
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="6"
                                MinHeight="0"
                                Click="TogglePassword_Click"
                                ToolTip="Show password">
                            <Path x:Name="EyeIcon"
                                  Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                  Fill="{StaticResource OnSurfaceVariantBrush}"
                                  Width="18"
                                  Height="18"
                                  Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <Border Background="{StaticResource ErrorContainerBrush}"
                            CornerRadius="20"
                            Padding="16,12"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,18">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource OnErrorContainerBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Background="{StaticResource SuccessContainerBrush}"
                            CornerRadius="20"
                            Padding="16,12"
                            Visibility="{Binding HasBootstrapMessage, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,18">
                        <TextBlock Text="{Binding BootstrapMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Button x:Name="SignInButton"
                            Content="Sign In"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="56"
                            FontSize="16"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                            Click="SignInButton_Click" />

                    <Border Height="56"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Control Style="{StaticResource LoadingSpinnerStyle}"
                                     Margin="0,0,10,0" />
                            <TextBlock Text="Signing in..."
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Button Content="Initialize admin account"
                            Command="{Binding BootstrapCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,10" />

                    <Border Background="{StaticResource SurfaceContainerLowBrush}"
                            CornerRadius="22"
                            Padding="16,12">
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   TextAlignment="Center">
                            <Run Text="Last login: " />
                            <Run Text="{Binding LastLoginUsername}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                            <Run Text=" at " />
                            <Run Text="{Binding LastLoginTime}" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
