<UserControl x:Class="BlueBirdsERP.Desktop.Views.CreditorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with action buttons -->
        <Border Grid.Row="0" Margin="0,0,0,24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding CreateBusinessAccountCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,7V3H2V21H22V7H12M10,19H4V17H10V19M10,15H4V13H10V15M10,11H4V9H10V11M10,7H4V5H10V7M20,19H12V17H20V19M20,15H12V13H20V15M20,11H12V9H20V11Z" Fill="White" Width="18" Height="18" Margin="0,0,8,0" />
                            <TextBlock Text="Business Account" VerticalAlignment="Center" FontWeight="Bold" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CreateOneTimeCreditorCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M15,14C12.33,14 7,15.33 7,18V20H23V18C23,15.33 17.67,14 15,14M6,10V7H4V10H1V12H4V15H6V12H9V10M15,12A4,4 0 0,0 19,8A4,4 0 0,0 15,4A4,4 0 0,0 11,8A4,4 0 0,0 15,12Z" Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="One-time Creditor" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Creditors Management" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Monitor outstanding balances and credit history" 
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Loading / Error -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <Control Style="{StaticResource LoadingSpinnerStyle}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Loading accounts..." Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" FontSize="13" />
            </StackPanel>
            
            <Border Background="{StaticResource ErrorContainerBrush}"
                    CornerRadius="22" Padding="16,12"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                          Fill="{StaticResource ErrorBrush}" Width="18" Height="18" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource OnErrorContainerBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- Left: Debtor aging buckets -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="24,20" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="DEBTOR AGING BUCKETS" Style="{StaticResource LabelStyle}" Margin="0" />
                    </Border>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <ItemsControl ItemsSource="{Binding DebtorBuckets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="20">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,16">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"
                                                           Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" />
                                                <Border DockPanel.Dock="Right" Background="{StaticResource ErrorContainerBrush}" CornerRadius="16" Padding="12,4">
                                                    <TextBlock Text="{Binding OutstandingBalance, Converter={StaticResource CurrencyFormat}}"
                                                               FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                                                </Border>
                                            </DockPanel>
                                            
                                            <ItemsControl ItemsSource="{Binding Invoices}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,10" Margin="0,0,0,4"
                                                                Background="{StaticResource SurfaceContainerLowBrush}"
                                                                CornerRadius="18">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding InvoiceNumber}" FontSize="12" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1" Text="{Binding CustomerName}" FontSize="12"
                                                                           Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="8,0" />
                                                                <TextBlock Grid.Column="2" Text="{Binding BalanceAmount, Converter={StaticResource CurrencyFormat}}"
                                                                           FontSize="12" FontWeight="Bold" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right: Selected customer detail -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0" Background="{StaticResource SurfaceElevatedBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="24,20" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="CUSTOMER PROFILE" Style="{StaticResource LabelStyle}" Margin="0" />
                    </Border>

                    <!-- Placeholder when no selection -->
                    <Border Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                            Padding="48">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M12,12C14.21,12 16,10.21 16,8C16,5.79 14.21,4 12,4C9.79,4 8,5.79 8,8C8,10.21 9.79,12 12,12M12,14C9.33,14 4,15.34 4,18V20H20V18C20,15.34 14.67,14 12,14Z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,24" Opacity="0.1" />
                            <TextBlock Text="Select a customer from the aging list" HorizontalAlignment="Center" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                            <TextBlock Text="to view their credit profile" HorizontalAlignment="Center" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Customer info (shown when selected) -->
                    <ScrollViewer Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVis}}" Padding="24">
                        <StackPanel>
                            <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="26" Padding="20" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedCustomer.Name}" FontWeight="Bold" FontSize="18" Foreground="{StaticResource OnSurfaceBrush}" />
                                    <Border Background="{StaticResource PrimaryContainerBrush}" CornerRadius="16" Padding="10,4" HorizontalAlignment="Left" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SelectedCustomer.AccountType}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Credit summary metrics -->
                            <TextBlock Text="CREDIT UTILIZATION" Style="{StaticResource LabelStyle}" Margin="0,0,0,12" />
                            <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,24" Background="White">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Outstanding" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding CreditSummary.OutstandingBalance, Converter={StaticResource CurrencyFormat}}" 
                                                   HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                                    </Grid>
                                    
                                    <!-- Progress bar meter -->
                                    <ProgressBar Height="8" Margin="0,8" Minimum="0" Maximum="100" Value="65" 
                                                 Background="{StaticResource SurfaceContainerBrush}" 
                                                 Foreground="{StaticResource ErrorBrush}" BorderThickness="0" />
                                    
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Credit Limit" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding CreditSummary.CreditLimit, Converter={StaticResource CurrencyFormat}}" 
                                                   HorizontalAlignment="Right" FontWeight="SemiBold" />
                                    </Grid>
                                    
                                    <Separator Style="{StaticResource SeparatorStyle}" Margin="0,16" />
                                    
                                    <UniformGrid Columns="2">
                                        <StackPanel>
                                            <TextBlock Text="AVAILABLE" Style="{StaticResource LabelStyle}" FontSize="10" />
                                            <TextBlock Text="{Binding CreditSummary.AvailableCredit, Converter={StaticResource CurrencyFormat}}" 
                                                       FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="OVERDUE" Style="{StaticResource LabelStyle}" FontSize="10" />
                                            <TextBlock Text="{Binding CreditSummary.OverdueInvoiceCount, StringFormat='{}{0} Invoices'}" 
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <Grid Margin="0,0,0,32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding RecordPaymentCommand}" Style="{StaticResource PrimaryButtonStyle}" Content="Record Payment" Grid.Column="0" />
                                <Button Command="{Binding EditTermsCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="Edit Terms" Grid.Column="2" />
                            </Grid>

                            <!-- Payment history -->
                            <TextBlock Text="RECENT PAYMENTS" Style="{StaticResource LabelStyle}" Margin="0,0,0,12" />
                            <DataGrid ItemsSource="{Binding PaymentHistory}"
                                      Style="{StaticResource DataGridStyle}"
                                      MaxHeight="300"
                                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource DataGridRowStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Inv #" Binding="{Binding InvoiceNumber}" Width="80" />
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='yyyy-MM-dd'}" Width="*" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, Converter={StaticResource CurrencyFormat}}" Width="110" FontWeight="Bold" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,24,0,0" Padding="16,10"
                Background="{StaticResource SurfaceContainerBrush}" CornerRadius="22">
            <StackPanel Orientation="Horizontal">
                <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" 
                      Fill="{StaticResource PrimaryBrush}" Width="16" Height="16" Margin="0,0,12,0" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium"
                           Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
