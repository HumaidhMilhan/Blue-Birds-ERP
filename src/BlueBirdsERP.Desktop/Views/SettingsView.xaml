<UserControl x:Class="BlueBirdsERP.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">

            <!-- Header with Status -->
            <DockPanel Margin="0,0,0,32">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Settings &amp; Configuration" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Store profile, users, backups, and notifications" Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Control Style="{StaticResource LoadingSpinnerStyle}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,0,12,0" />
                    
                    <Border Background="{StaticResource SuccessContainerBrush}" CornerRadius="12" Padding="16,8"
                            Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8L10,17z" 
                                  Fill="{StaticResource SuccessBrush}" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="Medium" FontSize="13" />
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource ErrorContainerBrush}" CornerRadius="12" Padding="16,8"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                                  Fill="{StaticResource ErrorBrush}" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource OnErrorContainerBrush}" FontWeight="Medium" FontSize="13" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>

            <!-- ============================================================ -->
            <!-- Profile Section -->
            <!-- ============================================================ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                              Fill="{StaticResource PrimaryBrush}" Width="24" Height="24" Margin="0,0,12,0" />
                        <TextBlock Text="My Profile" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="USERNAME" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProfileUsername}" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" />
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ACCOUNT ROLE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PrimaryContainerBrush}"
                                CornerRadius="16" Padding="12,4" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ProfileRole}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="11" />
                        </Border>
                    </Grid>
                    
                    <Button Content="Change Security Password"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="16,10" Margin="0,24,0,0"
                            IsEnabled="False" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- System Settings (Admin only) -->
            <!-- ============================================================ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="24"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Path Data="M12,15.5A3,3 0 0,1 9,12.5A3,3 0 0,1 12,9.5A3,3 0 0,1 15,12.5A3,3 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,5.93C16.04,5.55 15.48,5.23 14.88,5.03L14.5,2.42C14.46,2.18 14.25,2 14,2H10C10.75,2 10.54,2.18 10.5,2.42L10.12,5.03C9.52,5.23 8.96,5.55 8.44,5.93L5.95,5.05C5.73,4.97 5.46,5.05 5.34,5.27L3.34,8.73C3.22,8.95 3.27,9.22 3.46,9.37L5.57,11C5.53,11.34 5.5,11.67 5.5,12C5.5,12.33 5.53,12.65 5.57,12.97L3.46,14.63C3.27,14.78 3.22,15.05 3.34,15.27L5.34,18.73C5.46,18.95 5.73,19.03 5.95,18.95L8.44,18.07C8.96,18.45 9.52,18.77 10.12,18.97L10.5,21.58C10.54,21.82 10.75,22 11,22H15C15.25,22 15.46,21.82 15.5,21.58L15.88,18.97C16.48,18.77 17.04,18.45 17.56,18.07L20.05,18.95C20.27,19.03 20.54,18.95 20.66,18.73L22.66,15.27C22.78,15.05 22.73,14.78 22.54,14.63L20.43,12.97Z" 
                              Fill="{StaticResource PrimaryBrush}" Width="24" Height="24" Margin="0,0,12,0" />
                        <TextBlock Text="Store Information" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="COMPANY NAME" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ReceiptCompanyName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="RECEIPT HEADER" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ReceiptHeader, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RECEIPT FOOTER" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />
                                 
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="SYSTEM LOGO URL" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SystemLogoUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,16" />
                    </Grid>
                    
                    <Button Content="Update Store Info"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveSettingsCommand}"
                            Padding="24,12" Margin="0,8,0,0" HorizontalAlignment="Right" />
                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- User Management -->
            <!-- ============================================================ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="24"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="User Accounts" FontSize="18" FontWeight="Bold" Margin="0,0,0,24" />
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewCashierUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Tag="Enter cashier username"
                                 Width="300" HorizontalAlignment="Left" />
                        <Button Grid.Column="1" Content="Add Cashier"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateCashierCommand}"
                                Padding="20,12" />
                    </Grid>
                    
                    <DataGrid ItemsSource="{Binding Cashiers}" 
                              Style="{StaticResource DataGridStyle}" 
                              MaxHeight="250"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Fill" Value="{StaticResource OutlineBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="Active" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="Disabled" />
                                                                <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- Database & Logs -->
            <!-- ============================================================ -->
            <Grid Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="24" Height="24" Margin="0,0,12,0" />
                            <TextBlock Text="Database" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="STATUS" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding DbStatusMessage}" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="BACKUP PATH" Style="{StaticResource LabelStyle}" />
                            <TextBlock Text="{Binding BackupPath}" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <UniformGrid Columns="2">
                            <Button Content="Test Link" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding TestConnectionCommand}" Margin="0,0,6,0" />
                            <Button Content="Backup Now" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BackupDatabaseCommand}" Margin="6,0,0,0" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Audit Explorer" FontSize="18" FontWeight="Bold" Margin="0,0,0,24" />
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="FROM" Style="{StaticResource LabelStyle}" />
                                <DatePicker SelectedDate="{Binding AuditFromDate, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="TO" Style="{StaticResource LabelStyle}" />
                                <DatePicker SelectedDate="{Binding AuditToDate, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="Fetch Logs" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SearchAuditLogsCommand}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Notifications (Admin only) -->
            <Border Style="{StaticResource CardStyle}" Margin="0,24,0,32" Padding="24"
                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Notification Templates" FontSize="18" FontWeight="Bold" Margin="0,0,0,24" />
                    
                    <TextBlock Text="PAYMENT REMINDER" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding PaymentReminderTemplate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="80" Margin="0,0,0,20" />
                    
                    <TextBlock Text="OVERDUE ALERT" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding OverdueAlertTemplate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="80" Margin="0,0,0,20" />
                    
                    <Button Content="Save All Templates"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveTemplatesCommand}"
                            Padding="24,12" HorizontalAlignment="Right" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
