<UserControl x:Class="BlueBirdsERP.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
        <StackPanel>
            <DockPanel Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Operational Overview" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Live sales, stock, and collections at a glance"
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
            </DockPanel>

            <!-- Date range controls -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,32" Padding="20">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="12" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="FROM" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" Width="140" Margin="0,0,24,0" />
                                <TextBlock Text="TO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}" Width="140" />
                            </StackPanel>
                        </Border>
                        <Button Content="Refresh Dashboard"
                                Command="{Binding LoadReportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="16,0,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Control Style="{StaticResource LoadingSpinnerStyle}" 
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" 
                                 Margin="0,0,12,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Error -->
            <Border Background="{StaticResource ErrorContainerBrush}"
                    CornerRadius="12" Padding="20,16"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                          Fill="{StaticResource ErrorBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource OnErrorContainerBrush}" 
                               VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <!-- KPI Cards Row -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,32">
                <!-- Total Sales -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Primary" Margin="0,0,12,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="TOTAL SALES" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.58-1.05-2.77-2.65-3.12V5h-2v1.53c-1.45.31-2.63 1.21-2.63 2.66 0 1.73 1.45 2.58 3.57 3.1 2.02.49 2.42 1.21 2.42 1.89 0 .53-.33 1.36-2.15 1.36-1.79 0-2.43-.83-2.52-1.68h-1.73c.1 1.82 1.32 2.85 2.85 3.19V19h2v-1.58c1.51-.29 2.7-1.16 2.73-2.73.01-1.89-1.51-2.58-3.35-3.04z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="20" Height="20" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding TotalSales, StringFormat='Rs. {0:N2}'}"
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Gross Profit -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Success" Margin="6,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="GROSS PROFIT" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M16,6L18.29,8.29L13.41,13.17L10.41,10.17L2,18.59L3.41,20L10.41,13L13.41,16L19.71,9.71L22,12V6H16Z" 
                                  Fill="{StaticResource SuccessBrush}" Width="20" Height="20" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding GrossProfit, StringFormat='Rs. {0:N2}'}"
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Wastage -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Warning" Margin="6,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="WASTAGE VALUE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                  Fill="{StaticResource WarningBrush}" Width="20" Height="20" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding WastageValue, StringFormat='Rs. {0:N2}'}"
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Invoices -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Primary" Margin="12,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="INVOICES" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}" Width="20" Height="20" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding InvoiceCount}"
                                   FontSize="28" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Main Content Area -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Sales Breakdown -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sales Breakdown" Style="{StaticResource SectionHeaderStyle}" />
                        
                        <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Retail Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RetailSales, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" FontSize="16" />
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Wholesale Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WholesaleSales, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" FontSize="16" />
                            </Grid>
                        </Border>

                        <TextBlock Text="Payment Methods" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash Payments" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CashPayments, StringFormat='Rs. {0:N2}'}" FontWeight="SemiBold" />
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Card Payments" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CardPayments, StringFormat='Rs. {0:N2}'}" FontWeight="SemiBold" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right: Low Stock Alerts -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="Low Stock Alerts" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Left" Margin="0" />
                            <Border Background="{StaticResource WarningContainerBrush}" CornerRadius="16" Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="ACTION REQUIRED" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="Bold" />
                            </Border>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding LowStockItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource WarningContainerBrush}"
                                            BorderBrush="{StaticResource WarningBrush}"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,2,0,0">
                                                    <Run Text="Remaining:" />
                                                    <Run Text="{Binding RemainingQuantity, Mode=OneWay, StringFormat='{}{0:N1}'}" FontWeight="SemiBold" />
                                                    <Run Text="{Binding UnitOfMeasure, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="1" VerticalAlignment="Center" Padding="10,4" Background="{StaticResource SurfaceContainerLowestBrush}" CornerRadius="16">
                                                <TextBlock Text="{Binding ReorderLevel, StringFormat='Limit: {0:N1}'}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="12" Padding="24"
                                Visibility="{Binding LowStockItems.Count, FallbackValue=0, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,17H13V15H11V17M11,13H13V7H11V13Z" 
                                      Fill="{StaticResource SuccessBrush}" Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16" Opacity="0.5"/>
                                <TextBlock Text="Inventory health is good" Foreground="{StaticResource OnSurfaceVariantBrush}" FontWeight="Medium" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Debtor Aging Table -->
            <TextBlock Text="Debtor Aging &amp; Collections" Style="{StaticResource SectionHeaderStyle}" Margin="0,48,0,24" />
            
            <ItemsControl ItemsSource="{Binding DebtorBuckets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
                                <TextBlock Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="13" Margin="0,0,0,16">
                                    <Run Text="Total Outstanding:" />
                                    <Run Text="{Binding OutstandingBalance, StringFormat='Rs. {0:N2}'}" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                                </TextBlock>
                                
                                <Separator Style="{StaticResource SeparatorStyle}" Margin="0,0,0,16" />
                                
                                <ItemsControl ItemsSource="{Binding Invoices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="0,8" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding InvoiceNumber}" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding BalanceAmount, StringFormat='Rs. {0:N2}'}" 
                                                               VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
