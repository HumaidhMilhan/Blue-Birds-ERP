<UserControl x:Class="BlueBirdsERP.Desktop.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
        <StackPanel>
            <DockPanel Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Analytics Overview" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Performance, wastage, margin, and inventory flow"
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
            </DockPanel>

            <!-- Date range + Generate -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,32" Padding="20">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="12" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="FROM" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" Width="140" Margin="0,0,24,0" />
                                <TextBlock Text="TO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}" Width="140" />
                            </StackPanel>
                        </Border>
                        <Button Content="Generate Report"
                                Command="{Binding GenerateReportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="16,0,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Control Style="{StaticResource LoadingSpinnerStyle}" 
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" 
                                 Margin="0,0,12,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Error -->
            <Border Background="{StaticResource ErrorContainerBrush}"
                    CornerRadius="12" Padding="20,16"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                          Fill="{StaticResource ErrorBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource OnErrorContainerBrush}" 
                               VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
            </Border>

            <!-- KPI Row -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,32">
                <!-- Total Sales -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Primary" Margin="0,0,8,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="TOTAL SALES" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.58-1.05-2.77-2.65-3.12V5h-2v1.53c-1.45.31-2.63 1.21-2.63 2.66 0 1.73 1.45 2.58 3.57 3.1 2.02.49 2.42 1.21 2.42 1.89 0 .53-.33 1.36-2.15 1.36-1.79 0-2.43-.83-2.52-1.68h-1.73c.1 1.82 1.32 2.85 2.85 3.19V19h2v-1.58c1.51-.29 2.7-1.16 2.73-2.73.01-1.89-1.51-2.58-3.35-3.04z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding TotalSales, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Gross Profit -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Success" Margin="4,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="GROSS PROFIT" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M16,6L18.29,8.29L13.41,13.17L10.41,10.17L2,18.59L3.41,20L10.41,13L13.41,16L19.71,9.71L22,12V6H16Z" 
                                  Fill="{StaticResource SuccessBrush}" Width="18" Height="18" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding GrossProfit, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Margin -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Primary" Margin="4,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="MARGIN" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M7.07,18.24L18.24,7.07L16.83,5.66L5.66,16.83L7.07,18.24M10,8.5C10,9.33 9.33,10 8.5,10C7.67,10 7,9.33 7,8.5C7,7.67 7.67,7 8.5,7C9.33,7 10,7.67 10,8.5M17,15.5C17,16.33 16.33,17 15.5,17C14.67,17 14,16.33 14,15.5C14,14.67 14.67,14 15.5,14C16.33,14 17,14.67 17,15.5Z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding ProfitMargin, StringFormat='{}{0}%'}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Wastage -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Warning" Margin="4,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="WASTAGE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                  Fill="{StaticResource WarningBrush}" Width="18" Height="18" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding TotalWastage, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- Invoices -->
                <Border Style="{StaticResource KpiCardStyle}" Tag="Primary" Margin="8,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="INVOICES" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}" Width="18" Height="18" HorizontalAlignment="Right" />
                        </DockPanel>
                        <TextBlock Text="{Binding InvoiceCount}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Main Content Area -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    <!-- Sales Summary -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Sales Summary" Style="{StaticResource SectionHeaderStyle}" />
                            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Retail Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RetailSales, Converter={StaticResource CurrencyFormat}}" FontWeight="Bold" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Wholesale Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WholesaleSales, Converter={StaticResource CurrencyFormat}}" FontWeight="Bold" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Profit Analysis -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Profit Analysis" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gross Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GrossSales, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Cost of Goods Sold" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CostOfGoodsSold, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}" />
                            </Grid>
                            <Border Background="{StaticResource SuccessContainerBrush}" CornerRadius="12" Padding="20,16">
                                <DockPanel>
                                    <TextBlock Text="NET GROSS PROFIT" FontWeight="Bold" DockPanel.Dock="Left" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding GrossProfit, Converter={StaticResource CurrencyFormat}}" FontSize="20" FontWeight="Bold"
                                               HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" />
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Payment Collections -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Payment Collections" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CashPayments, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Card" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CardPayments, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Refunds &amp; Returns" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TotalRefunds, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErrorBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">
                    <!-- Wastage Detail -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Wastage &amp; Returns" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Stock Wastage Value" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalWastage, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Customer Returns Value" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalReturnValue, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Wastage Events" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WastageCount}" FontWeight="Bold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Stock On Hand -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Critical Stock Levels" Style="{StaticResource SectionHeaderStyle}" />
                            <DataGrid ItemsSource="{Binding StockOnHand}"
                                      Style="{StaticResource DataGridStyle}" MaxHeight="300"
                                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource DataGridRowStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                    <DataGridTextColumn Header="Stock" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="80" />
                                    <DataGridTextColumn Header="Limit" Binding="{Binding ReorderLevel, StringFormat='{}{0:N1}'}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Batch Movements -->
            <TextBlock Text="Inventory Flow Analysis" Style="{StaticResource SectionHeaderStyle}" Margin="0,24,0,24" />
            <Border Style="{StaticResource CardStyle}">
                <DataGrid ItemsSource="{Binding BatchMovements}"
                          Style="{StaticResource DataGridStyle}" MaxHeight="400"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="Stock In" Binding="{Binding PurchasedQuantity, StringFormat='{}{0:N1}'}" Width="100" />
                        <DataGridTextColumn Header="Stock Out" Binding="{Binding SoldQuantity, StringFormat='{}{0:N1}'}" Width="100" />
                        <DataGridTextColumn Header="Wasted" Binding="{Binding WastedQuantity, StringFormat='{}{0:N1}'}" Width="100" />
                        <DataGridTextColumn Header="Net Remaining" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
