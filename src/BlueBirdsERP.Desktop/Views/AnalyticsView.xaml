<UserControl x:Class="BlueBirdsERP.Desktop.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Date range + Generate -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FROM" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}" Width="160" Margin="0,0,16,0" />
                    <TextBlock Text="TO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}" Width="160" Margin="0,0,16,0" />
                    <Button Content="Generate Report"
                            Command="{Binding GenerateReportCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="20,8" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Loading / Error -->
            <TextBlock Text="Generating report..."
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <Border Background="{StaticResource ErrorContainerBrush}"
                    CornerRadius="4" Padding="10,6"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,12">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource OnErrorContainerBrush}" />
            </Border>

            <!-- KPI Row -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">
                <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL SALES" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding TotalSales, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="GROSS PROFIT" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding GrossProfit, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="MARGIN" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding ProfitMargin, StringFormat='{}{0}%'}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="WASTAGE" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding TotalWastage, Converter={StaticResource CurrencyFormat}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="INVOICES" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding InvoiceCount}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two-column detail sections -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0">
                    <!-- Sales Summary -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Sales Summary" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Retail Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RetailSales, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Wholesale Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WholesaleSales, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Profit Analysis -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Profit Analysis" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gross Sales" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GrossSales, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cost of Goods Sold" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CostOfGoodsSold, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8" Background="{StaticResource OutlineVariantBrush}" />
                            </Grid>
                            <DockPanel>
                                <TextBlock Text="Gross Profit" FontWeight="Bold" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding GrossProfit, Converter={StaticResource CurrencyFormat}}" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Payment Collections -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Payment Collections" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CashPayments, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Card" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CardPayments, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Refunds" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalRefunds, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErrorBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="2">
                    <!-- Wastage -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Wastage" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Wastage" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalWastage, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Customer Returns" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CustomerReturnWastage, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Records" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WastageCount}" FontWeight="SemiBold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Sales Returns -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Sales Returns" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Returned Value" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalReturnValue, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Refunded" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalRefundAmount, Converter={StaticResource CurrencyFormat}}" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Returns" Foreground="{StaticResource OnSurfaceVariantBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ReturnCount}" FontWeight="SemiBold" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Stock On Hand -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Stock On Hand" Style="{StaticResource SectionHeaderStyle}" />
                            <DataGrid ItemsSource="{Binding StockOnHand}"
                                      Style="{StaticResource DataGridStyle}" MaxHeight="250">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}" />
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                    <DataGridTextColumn Header="UoM" Binding="{Binding UnitOfMeasure}" Width="60" />
                                    <DataGridTextColumn Header="Stock" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="70" />
                                    <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevel, StringFormat='{}{0:N1}'}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Batch Movements -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Batch Movements" Style="{StaticResource SectionHeaderStyle}" />
                    <DataGrid ItemsSource="{Binding BatchMovements}"
                              Style="{StaticResource DataGridStyle}" MaxHeight="300">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}" />
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Purchased" Binding="{Binding PurchasedQuantity, StringFormat='{}{0:N1}'}" Width="90" />
                            <DataGridTextColumn Header="Sold" Binding="{Binding SoldQuantity, StringFormat='{}{0:N1}'}" Width="80" />
                            <DataGridTextColumn Header="Wasted" Binding="{Binding WastedQuantity, StringFormat='{}{0:N1}'}" Width="80" />
                            <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQuantity, StringFormat='{}{0:N1}'}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
