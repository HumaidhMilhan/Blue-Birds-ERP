<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Skybound Utility — Monochromatic Blue Palette -->

    <!-- Primary -->
    <Color x:Key="PrimaryColor">#003d9b</Color>
    <Color x:Key="PrimaryContainerColor">#0052cc</Color>
    <Color x:Key="OnPrimaryColor">#ffffff</Color>
    <Color x:Key="OnPrimaryContainerColor">#c4d2ff</Color>
    <Color x:Key="InversePrimaryColor">#b2c5ff</Color>

    <!-- Secondary -->
    <Color x:Key="SecondaryColor">#585f6a</Color>
    <Color x:Key="SecondaryContainerColor">#dce3f0</Color>
    <Color x:Key="OnSecondaryColor">#ffffff</Color>
    <Color x:Key="OnSecondaryContainerColor">#5e6570</Color>

    <!-- Tertiary -->
    <Color x:Key="TertiaryColor">#1e4184</Color>
    <Color x:Key="TertiaryContainerColor">#3a599d</Color>
    <Color x:Key="OnTertiaryColor">#ffffff</Color>
    <Color x:Key="OnTertiaryContainerColor">#c3d3ff</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceColor">#f9f9ff</Color>
    <Color x:Key="SurfaceDimColor">#cedbf2</Color>
    <Color x:Key="SurfaceBrightColor">#f9f9ff</Color>
    <Color x:Key="SurfaceContainerLowestColor">#ffffff</Color>
    <Color x:Key="SurfaceContainerLowColor">#f0f3ff</Color>
    <Color x:Key="SurfaceContainerColor">#e7eeff</Color>
    <Color x:Key="SurfaceContainerHighColor">#dee9ff</Color>
    <Color x:Key="SurfaceContainerHighestColor">#d7e3fb</Color>

    <!-- On-Surface -->
    <Color x:Key="OnSurfaceColor">#101c2d</Color>
    <Color x:Key="OnSurfaceVariantColor">#434654</Color>
    <Color x:Key="InverseSurfaceColor">#253143</Color>
    <Color x:Key="InverseOnSurfaceColor">#ebf1ff</Color>

    <!-- Outline -->
    <Color x:Key="OutlineColor">#737685</Color>
    <Color x:Key="OutlineVariantColor">#c3c6d6</Color>

    <!-- Error -->
    <Color x:Key="ErrorColor">#ba1a1a</Color>
    <Color x:Key="OnErrorColor">#ffffff</Color>
    <Color x:Key="ErrorContainerColor">#ffdad6</Color>
    <Color x:Key="OnErrorContainerColor">#93000a</Color>

    <!-- Background -->
    <Color x:Key="BackgroundColor">#f9f9ff</Color>
    <Color x:Key="OnBackgroundColor">#101c2d</Color>

    <!-- Semantic (kept for status indicators) -->
    <Color x:Key="SuccessColor">#2e7d32</Color>
    <Color x:Key="SuccessContainerColor">#e8f5e9</Color>
    <Color x:Key="WarningColor">#ed6c02</Color>
    <Color x:Key="WarningContainerColor">#fff3e0</Color>
    <Color x:Key="InfoColor">#0288d1</Color>
    <Color x:Key="InfoContainerColor">#e1f5fe</Color>

    <!-- ============================================================ -->
    <!-- Brushes — Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource OnPrimaryContainerColor}" />
    <SolidColorBrush x:Key="InversePrimaryBrush" Color="{StaticResource InversePrimaryColor}" />

    <!-- Brushes — Secondary -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="{StaticResource SecondaryContainerColor}" />
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="{StaticResource OnSecondaryColor}" />

    <!-- Brushes — Tertiary -->
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="{StaticResource TertiaryContainerColor}" />

    <!-- Brushes — Surfaces -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceDimBrush" Color="{StaticResource SurfaceDimColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="{StaticResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="{StaticResource SurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource SurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="{StaticResource SurfaceContainerHighestColor}" />

    <!-- Brushes — On-Surface -->
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="InverseSurfaceBrush" Color="{StaticResource InverseSurfaceColor}" />
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="{StaticResource InverseOnSurfaceColor}" />

    <!-- Brushes — Outline -->
    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{StaticResource OutlineVariantColor}" />

    <!-- Brushes — Error -->
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="OnErrorBrush" Color="{StaticResource OnErrorColor}" />
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="{StaticResource ErrorContainerColor}" />
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="{StaticResource OnErrorContainerColor}" />

    <!-- Brushes — Background -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="OnBackgroundBrush" Color="{StaticResource OnBackgroundColor}" />

    <!-- Brushes — Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessContainerBrush" Color="{StaticResource SuccessContainerColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningContainerBrush" Color="{StaticResource WarningContainerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoContainerBrush" Color="{StaticResource InfoContainerColor}" />

    <!-- Backward-compat aliases (remove after full migration) -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource TertiaryColor}" />

</ResourceDictionary>
