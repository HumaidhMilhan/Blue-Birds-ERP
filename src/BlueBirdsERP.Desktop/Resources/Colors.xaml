<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- BlueBirds Material You design system: soft tablet-first ERP palette -->

    <!-- Core roles -->
    <Color x:Key="PrimaryColor">#386A8F</Color>
    <Color x:Key="PrimaryHoverColor">#225276</Color>
    <Color x:Key="PrimaryAccentColor">#5EA8D7</Color>
    <Color x:Key="PrimaryContainerColor">#D3ECFA</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="OnPrimaryContainerColor">#0B334A</Color>
    <Color x:Key="InversePrimaryColor">#A6D4F2</Color>

    <Color x:Key="SecondaryColor">#4F6359</Color>
    <Color x:Key="SecondaryContainerColor">#D2E8DB</Color>
    <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
    <Color x:Key="OnSecondaryContainerColor">#0C2016</Color>

    <Color x:Key="TertiaryColor">#7A5D92</Color>
    <Color x:Key="TertiaryContainerColor">#F1DAFF</Color>
    <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
    <Color x:Key="OnTertiaryContainerColor">#2F1748</Color>

    <!-- Soft accent containers -->
    <Color x:Key="BluePastelColor">#D3ECFA</Color>
    <Color x:Key="SagePastelColor">#D2E8DB</Color>
    <Color x:Key="ButterPastelColor">#FFE8B2</Color>
    <Color x:Key="CoralPastelColor">#FFDAD4</Color>
    <Color x:Key="LavenderPastelColor">#F1DAFF</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceColor">#FFF8FD</Color>
    <Color x:Key="SurfaceDimColor">#E6DFE7</Color>
    <Color x:Key="SurfaceBrightColor">#FFF8FD</Color>
    <Color x:Key="SurfaceContainerLowestColor">#FFFFFF</Color>
    <Color x:Key="SurfaceContainerLowColor">#FEF1F8</Color>
    <Color x:Key="SurfaceContainerColor">#F8ECF4</Color>
    <Color x:Key="SurfaceContainerHighColor">#F1E7F0</Color>
    <Color x:Key="SurfaceContainerHighestColor">#E9E0EA</Color>
    <Color x:Key="CanvasColor">#FFF8FD</Color>
    <Color x:Key="SidebarColor">#F3EDF7</Color>
    <Color x:Key="TopBarBorderColor">#E7DDE8</Color>
    <Color x:Key="TableHeaderColor">#F1E7F0</Color>
    <Color x:Key="FieldColor">#F6EFF7</Color>

    <!-- Text and outlines -->
    <Color x:Key="OnSurfaceColor">#1D1B20</Color>
    <Color x:Key="OnSurfaceVariantColor">#655F69</Color>
    <Color x:Key="InverseSurfaceColor">#322F35</Color>
    <Color x:Key="InverseOnSurfaceColor">#F5EFF7</Color>
    <Color x:Key="OutlineColor">#7D747F</Color>
    <Color x:Key="OutlineVariantColor">#D1C4D2</Color>

    <!-- Feedback -->
    <Color x:Key="ErrorColor">#BA1A1A</Color>
    <Color x:Key="OnErrorColor">#FFFFFF</Color>
    <Color x:Key="ErrorContainerColor">#FFDAD6</Color>
    <Color x:Key="OnErrorContainerColor">#410002</Color>
    <Color x:Key="SuccessColor">#2D6B3F</Color>
    <Color x:Key="SuccessContainerColor">#CDEECD</Color>
    <Color x:Key="WarningColor">#785900</Color>
    <Color x:Key="WarningContainerColor">#FFE8B2</Color>
    <Color x:Key="InfoColor">#386A8F</Color>
    <Color x:Key="InfoContainerColor">#D3ECFA</Color>

    <!-- Background -->
    <Color x:Key="BackgroundColor">#FFF8FD</Color>
    <Color x:Key="OnBackgroundColor">#1D1B20</Color>

    <!-- Brushes: Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccentColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource OnPrimaryContainerColor}" />
    <SolidColorBrush x:Key="InversePrimaryBrush" Color="{StaticResource InversePrimaryColor}" />

    <!-- Brushes: Secondary/Tertiary -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="{StaticResource SecondaryContainerColor}" />
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="{StaticResource OnSecondaryColor}" />
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="{StaticResource OnSecondaryContainerColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="{StaticResource TertiaryContainerColor}" />
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="{StaticResource OnTertiaryContainerColor}" />

    <!-- Brushes: Accent containers -->
    <SolidColorBrush x:Key="BluePastelBrush" Color="{StaticResource BluePastelColor}" />
    <SolidColorBrush x:Key="SagePastelBrush" Color="{StaticResource SagePastelColor}" />
    <SolidColorBrush x:Key="ButterPastelBrush" Color="{StaticResource ButterPastelColor}" />
    <SolidColorBrush x:Key="CoralPastelBrush" Color="{StaticResource CoralPastelColor}" />
    <SolidColorBrush x:Key="LavenderPastelBrush" Color="{StaticResource LavenderPastelColor}" />

    <!-- Brushes: Surfaces -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceDimBrush" Color="{StaticResource SurfaceDimColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="{StaticResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="{StaticResource SurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource SurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="{StaticResource SurfaceContainerHighestColor}" />
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="{StaticResource TopBarBorderColor}" />
    <SolidColorBrush x:Key="TableHeaderBrush" Color="{StaticResource TableHeaderColor}" />
    <SolidColorBrush x:Key="FieldBrush" Color="{StaticResource FieldColor}" />

    <!-- Brushes: Text and outlines -->
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="InverseSurfaceBrush" Color="{StaticResource InverseSurfaceColor}" />
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="{StaticResource InverseOnSurfaceColor}" />
    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{StaticResource OutlineVariantColor}" />

    <!-- Brushes: Feedback -->
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="OnErrorBrush" Color="{StaticResource OnErrorColor}" />
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="{StaticResource ErrorContainerColor}" />
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="{StaticResource OnErrorContainerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessContainerBrush" Color="{StaticResource SuccessContainerColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningContainerBrush" Color="{StaticResource WarningContainerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoContainerBrush" Color="{StaticResource InfoContainerColor}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="OnBackgroundBrush" Color="{StaticResource OnBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource PrimaryColor}" Opacity="0.08" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="{StaticResource PrimaryColor}" Opacity="0.14" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource OutlineVariantColor}" />

    <!-- Soft scenic gradients for tablet-style surfaces -->
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D3ECFA" Offset="0.0" />
        <GradientStop Color="#D2E8DB" Offset="0.52" />
        <GradientStop Color="#F1DAFF" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LoginPanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EAF6FE" Offset="0.0" />
        <GradientStop Color="#FFF3DB" Offset="0.56" />
        <GradientStop Color="#F4E5FF" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Backward-compat aliases used by existing views/dialogs -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryHoverColor}" />

</ResourceDictionary>
